pipeline {
    agent {
        label 'microservice'
    }
    stages {
        stage('git-checkout') {
            steps {
				dir('git-repo') {
					git branch: 'main', url: 'https://github.com/devsecopstrainer/student-service.git'
				}
			}
        }
        stage('mvn-build') {
            steps {
				dir('git-repo') {
					sh 'mvn clean package'
				}
            }
        }
		stage('SonarQube Analysis') {
			steps {
				dir('git-repo') {
					withSonarQubeEnv('SonarServer') {
						sh 'mvn sonar:sonar -Dsonar.projectKey=student-service'
					}
				}
			}
		}
        stage('Quality Gate') {
            steps {
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
        stage('upload-to-nexus') {
            steps {
                sh 'mvn deploy'
            }
        }
        stage('Checkout Dockerfile') {
            steps {
                dir('docker-repo') {
                    git branch: 'main', url: 'https://github.com/devsecopstrainer/cicd.git'
                }
            }
        }
        stage('Docker build') {
            steps {
               sh 'docker build -f docker-repo/student-service-Dockerfile -t student-svc:${BUILD_NUMBER} .'
            }
        }
    }
}
